generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Tabela de Usuários (O dono das contas)
model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  password     String        // Aqui vai a senha criptografada
  transactions Transaction[] // Relação: Um usuário tem várias transações
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("users")
}

// Tabela de Transações (Agora com dono!)
model Transaction {
  id           String   @id @default(uuid())
  description  String
  amount       Float
  type         String   // 'income' ou 'expense'
  dueDate      DateTime
  paymentDate  DateTime?
  status       String   @default("pending")
  
  // Relacionamento: Toda transação agora pertence a um User
  userId       String
  user         User     @relation(fields: [userId], references: [id])

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("transactions")
}